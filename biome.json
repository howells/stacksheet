{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"extends": ["@howells/lint/biome/react"],
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!!**/node_modules",
			"!!dist",
			"!!dist",
			"!!site/.next",
			"!!site/.next",
			"!!.vercel",
			"!!.vercel"
		]
	},
	"overrides": [
		{
			"includes": ["**/src/index.ts", "**/src/index.tsx"],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"useFilenamingConvention": {
							"level": "error",
							"options": {
								"filenameCases": ["PascalCase", "kebab-case"]
							}
						}
					}
				}
			}
		}
	]
}
